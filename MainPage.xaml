<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AppOpenerAndTimer.Models"
             x:Class="AppOpenerAndTimer.MainPage"
             Title="App Opener and Timer">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="14" RowSpacing="10">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="App Opener and Timer" FontSize="22" FontAttributes="Bold" />
            <Label Text="Tick the apps to open, then press Go. Each launches one interval apart; a timer tracks how long since each opened."
                   FontSize="12" TextColor="Gray" />
        </VerticalStackLayout>

        <!-- Interval + permission -->
        <VerticalStackLayout Grid.Row="1" Spacing="8">
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="Seconds between launches:" VerticalOptions="Center" />
                <Entry x:Name="IntervalEntry" Text="60" Keyboard="Numeric" WidthRequest="70" />
            </HorizontalStackLayout>
            <Frame x:Name="OverlayWarning" IsVisible="False" Padding="8" BorderColor="OrangeRed" CornerRadius="6">
                <VerticalStackLayout Spacing="6">
                    <Label Text="⚠ 'Display over other apps' is off. Without it, Android blocks launching apps while this one is in the background."
                           FontSize="12" />
                    <Button Text="Grant permission" Clicked="OnGrantOverlay" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <!-- Action buttons -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
            <Button Grid.Column="0" x:Name="GoButton" Text="▶ Go" Clicked="OnGo" />
            <Button Grid.Column="1" Text="■ Stop" Clicked="OnStop" />
            <Button Grid.Column="2" Text="↻ Reset" Clicked="OnReset" />
            <Button Grid.Column="3" Text="⟳ Apps" Clicked="OnRefresh" />
        </Grid>

        <!-- App checklist -->
        <CollectionView Grid.Row="3" x:Name="AppsView" ItemsSource="{Binding Apps}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AppEntry">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="4,8" ColumnSpacing="8">
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="{Binding Label}" FontSize="16" />
                            <Label Text="{Binding Status}" FontSize="11" TextColor="Gray" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="{Binding ElapsedText}" FontSize="18"
                               FontFamily="Monospace" VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="Loading installed apps…" HorizontalOptions="Center" Margin="0,40,0,0" />
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Status bar -->
        <Label Grid.Row="4" x:Name="StatusLabel" Text="Ready." FontSize="12" TextColor="Gray" />
    </Grid>
</ContentPage>
